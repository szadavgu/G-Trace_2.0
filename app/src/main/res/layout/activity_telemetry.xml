<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <hu.unideb.inf.g_trace.GForceView
        android:id="@+id/gForceVisual"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/txtCurrentG"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.00 G"
        android:textColor="#FF1801"
        android:textSize="48sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtMaxG"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MAX: 0.00 G"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnStop"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="STOP SESSION"
        android:backgroundTint="#FF1801"
        android:textColor="#FFFFFF"
        android:onClick="stopTelemetry" />

</LinearLayout>